NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
# Local dev: mongodb://localhost:27017/worldcup_predictions
# Docker:    mongodb://mongodb:27017/worldcup_predictions
MONGO_URI=mongodb://localhost:27017/worldcup_predictions

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

SUPER_ADMIN_FULL_NAME=مدیر اصلی
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change_this_password

FOOTBALL_API_PROVIDER=football-data
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=your_football_data_api_key_here
FOOTBALL_COMPETITION_CODE=WC
FOOTBALL_SEASON=2026
FOOTBALL_DEFAULT_TIMEZONE=Asia/Tehran

SYNC_ENABLED=true
SYNC_CRON=*/30 * * * *
SYNC_ACTIVE_MATCHDAY_CRON=*/5 * * * *

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
